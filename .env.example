# LLM provider
# The installed requirements support OpenAI and Groq.
CHAT_MODEL_PROVIDER=groq
CHAT_MODEL=llama-3.3-70b-versatile
CHAT_MODEL_FAST=llama-3.1-8b-instant
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_TEMPERATURE=0.0

# Companies House
COMPANIES_HOUSE_API_KEY=
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk

# FCA Register
FCA_API_KEY=
FCA_API_EMAIL=
FCA_BASE_URL=https://register.fca.org.uk/services/V0.1

# Optional legacy NewsAPI connector
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

# Brave Search
BRAVE_SEARCH_API_KEY=

# OpenSanctions
OPEN_SANCTIONS_API_KEY=
OPEN_SANCTIONS_BASE_URL=https://api.opensanctions.org

# Research behaviour
USE_MOCK_DATA=true
MAX_FOLLOWUP_ITERATIONS=2
CONFIDENCE_THRESHOLD=0.6

# Browser access to the API, comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic_company_research_poc
